# ============================================
# FRONTEND ENVIRONMENT VARIABLES (EXAMPLE)
# ============================================

# Application
VITE_APP_NAME="Security Assessment Platform"
VITE_APP_ENV=production
VITE_APP_DEBUG=false

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_PREFIX=/api/v1

# WebSocket Configuration
VITE_WS_URL=ws://localhost:3000
VITE_WS_PATH=/socket.io

# Features
VITE_ENABLE_2FA=true
VITE_ENABLE_REALTIME=true
VITE_ENABLE_DARK_MODE=true

# Upload
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,doc,docx,xls,xlsx

# Pagination
VITE_DEFAULT_PAGE_SIZE=15
VITE_PAGE_SIZES=10,15,25,50,100